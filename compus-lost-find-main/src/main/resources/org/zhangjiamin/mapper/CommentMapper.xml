<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.zhangjiamin.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="org.zhangjiamin.entity.Comment">
        <id column="comment_id" property="commentId"/>
        <result column="item_id" property="itemId"/>
        <result column="user_id" property="userId"/>
        <result column="user_nickname" property="userNickname"/>
        <result column="user_avatar" property="userAvatar"/>
        <result column="content" property="content"/>
        <result column="parent_id" property="parentId"/>
        <result column="create_time" property="createTime"/>
        <result column="is_read" property="isRead"/>
    </resultMap>

    <sql id="BaseColumns">
        comment_id, item_id, user_id, user_nickname, user_avatar,
        content, parent_id, create_time, is_read
    </sql>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM comments WHERE comment_id = #{commentId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO comments (item_id, user_id, user_nickname, user_avatar, content, parent_id)
        VALUES (#{itemId}, #{userId}, #{userNickname}, #{userAvatar}, #{content}, #{parentId})
    </insert>

    <delete id="deleteById">
        DELETE FROM comments WHERE comment_id = #{commentId}
    </delete>

    <delete id="deleteByItemId">
        DELETE FROM comments WHERE item_id = #{itemId}
    </delete>

    <select id="findByItemId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM comments WHERE item_id = #{itemId}
        ORDER BY create_time ASC
    </select>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM comments WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <update id="markAsRead">
        UPDATE comments SET is_read = 1 WHERE comment_id = #{commentId}
    </update>

    <select id="countByItemId" resultType="int">
        SELECT COUNT(*) FROM comments WHERE item_id = #{itemId}
    </select>

</mapper>
